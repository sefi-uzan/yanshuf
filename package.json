{
  "name": "yanshuf",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start --filter=@yanshuf/desktop",
    "make": "turbo run make --filter=@yanshuf/desktop",
    "package": "turbo run package --filter=@yanshuf/desktop",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@yanshuf/desktop"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron-winstaller",
      "fs-xattr",
      "macos-alias",
      "unrs-resolver"
    ]
  }
}
