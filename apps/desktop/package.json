{
  "name": "@yanshuf/desktop",
  "productName": "Yanshuf",
  "version": "1.0.0",
  "description": "macOS network proxy for inspecting HTTP/HTTPS traffic",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "pnpm --filter @yanshuf/mcp build && electron-forge start",
    "package": "electron-forge package",
    "make": "pnpm --filter @yanshuf/mcp build && electron-forge make",
    "icons": "bash scripts/build-icons.sh",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "electron",
    "proxy",
    "mitm",
    "macos"
  ],
  "author": {
    "name": "Sefi",
    "email": "sefiuzan812@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@yanshuf/shared": "workspace:*",
    "@yanshuf/ui": "workspace:*",
    "http-mitm-proxy": "^1.1.0",
    "lucide-react": "^1.20.0",
    "node-forge": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "undici": "^8.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.61.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@yanshuf/eslint-config": "workspace:*",
    "@yanshuf/tailwind-config": "workspace:*",
    "@yanshuf/typescript-config": "workspace:*",
    "autoprefixer": "^10.5.0",
    "electron": "42.4.1",
    "eslint": "^8.57.1",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
